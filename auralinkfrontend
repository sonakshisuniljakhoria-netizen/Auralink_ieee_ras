<button class="flex flex-col items-center justify-center text-primary-fixed-dim font-bold transition-all px-4 py-1 rounded-xl bg-primary-fixed-dim/10" id="btn-twin" onclick="switchTab('twin', this)">
<span class="material-symbols-outlined text-2xl">grid_view</span>
<span class="text-[10px] font-bold mt-1 uppercase tracking-tighter">Twin</span>
</button>
<button class="flex flex-col items-center justify-center text-on-surface-variant transition-all" id="btn-stylist" onclick="switchTab('stylist', this)">
<span class="material-symbols-outlined text-2xl">auto_awesome</span>
<span class="text-[10px] font-bold mt-1 uppercase tracking-tighter">Stylist</span>
</button>
<button class="flex flex-col items-center justify-center text-on-surface-variant transition-all" id="btn-guardian" onclick="switchTab('guardian', this)">
<span class="material-symbols-outlined text-2xl">security</span>
<span class="text-[10px] font-bold mt-1 uppercase tracking-tighter">Guardian</span>
</button>
<button class="flex flex-col items-center justify-center text-on-surface-variant transition-all" id="btn-track" onclick="switchTab('track', this)">
<span class="material-symbols-outlined text-2xl">location_on</span>
<span class="text-[10px] font-bold mt-1 uppercase tracking-tighter">Track</span>
</button>
</nav>
<script>
    function switchTab(tabId, element) {
        const sections = ['view-twin', 'view-stylist', 'view-guardian', 'view-track'];
        sections.forEach(id => {
            document.getElementById(id).classList.add('hidden');
        });

        document.getElementById(`view-${tabId}`).classList.remove('hidden');

        const navButtons = document.querySelectorAll('nav button');
        navButtons.forEach(btn => {
            btn.className = "flex flex-col items-center justify-center text-on-surface-variant transition-all";
            btn.classList.remove('bg-primary-fixed-dim/10', 'text-primary-fixed-dim', 'font-bold');
        });

        element.className = "flex flex-col items-center justify-center text-primary-fixed-dim font-bold transition-all px-4 py-1 rounded-xl bg-primary-fixed-dim/10";
    }

    function toggleHotspot(id) {
        const allHotspots = document.querySelectorAll('.schematic-hotspot');
        const allCallouts = document.querySelectorAll('.schematic-callout');
        const currentHotspot = document.querySelector(`[data-target="${id}"]`);
        const currentCallout = document.querySelector(`[data-for="${id}"]`);
        const isActive = currentHotspot.classList.contains('active');
        allHotspots.forEach(h => h.classList.remove('active'));
        allCallouts.forEach(c => c.classList.remove('active'));
        if (!isActive) {
            currentHotspot.classList.add('active');
            currentCallout.classList.add('active');
        }
    }

    document.getElementById('schematic-container').addEventListener('click', (e) => {
        if (e.target.id === 'schematic-container' || e.target.tagName === 'IMG') {
            document.querySelectorAll('.schematic-hotspot').forEach(h => h.classList.remove('active'));
            document.querySelectorAll('.schematic-callout').forEach(c => c.classList.remove('active'));
        }
    });

    let vh = window.innerHeight * 0.01;
    document.documentElement.style.setProperty('--vh', `${vh}px`);
    window.addEventListener('resize', () => {
        let vh = window.innerHeight * 0.01;
        document.documentElement.style.setProperty('--vh', `${vh}px`);
    });
</script>
</body></html>