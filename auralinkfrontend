<script>
    // Navigation Highlighting and Smooth Scrolling Logic
    const sections = document.querySelectorAll('section');
    const navLinks = document.querySelectorAll('.nav-link');

    // Smooth Scroll Helper with Regal Easing
    function scrollToSection(id) {
      const target = document.querySelector(id);
      if (!target) return;
      
      const offset = 80; // Alignment offset
      const bodyRect = document.body.getBoundingClientRect().top;
      const elementRect = target.getBoundingClientRect().top;
      const elementPosition = elementRect - bodyRect;
      const offsetPosition = elementPosition - offset;

      window.scrollTo({
        top: offsetPosition,
        behavior: 'smooth'
      });
    }

    // Attach click events to nav links
    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.getAttribute('href');
        scrollToSection(targetId);
      });
    });

    // Intersection Observer for highlighting nav items
    const observerOptions = {
      root: null,
      rootMargin: '-10% 0px -70% 0px', // Trigger when section is near the top
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === `#${id}`) {
              link.classList.add('active');
            }
          });
        }
      });
    }, observerOptions);

    sections.forEach(section => observer.observe(section));

    // Heart Rate Pulse Animation Logic
    setInterval(() => {
      const heartChart = document.getElementById('heart-chart');
      if (!heartChart) return;
      const bars = heartChart.querySelectorAll('div');
      bars.forEach(bar => {
        const height = Math.floor(Math.random() * 50) + 30;
        bar.style.height = `${height}%`;
      });
    }, 1000);

    // SOS Slider Logic
    const handle = document.getElementById('sos-handle');
    const container = document.getElementById('sos-slider-container');
    const progress = document.getElementById('sos-progress');
    let isDragging = false;
    let startX = 0;
    
    const startDrag = (e) => {
      isDragging = true;
      startX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
      handle.style.transition = 'none';
    };

    const onDrag = (e) => {
      if (!isDragging) return;
      const currentX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
      const rect = container.getBoundingClientRect();
      const maxTranslate = rect.width - handle.offsetWidth - 16; 
      let diff = currentX - startX;
      
      diff = Math.max(0, Math.min(diff, maxTranslate));
      handle.style.transform = `translateX(${diff}px)`;
      progress.style.width = `${(diff / maxTranslate) * 100}%`;

      if (diff >= maxTranslate - 2) {
        triggerSOS();
      }
    };

    const endDrag = () => {
      if (!isDragging) return;
      isDragging = false;
      handle.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
      progress.style.transition = 'width 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
      handle.style.transform = 'translateX(0)';
      progress.style.width = '0';
      setTimeout(() => {
        progress.style.transition = 'none';
      }, 500);
    };

    function triggerSOS() {
      if (!isDragging) return;
      isDragging = false;
      alert('SILENT SOS PROTOCOL ENGAGED: Guardians notified. Real-time audio streaming active.');
      handle.style.transform = 'translateX(0)';
      progress.style.width = '0';
    }

    if (handle && container) {
      handle.addEventListener('mousedown', startDrag);
      handle.addEventListener('touchstart', startDrag);
      window.addEventListener('mousemove', onDrag);
      window.addEventListener('touchmove', onDrag);
      window.addEventListener('mouseup', endDrag);
      window.addEventListener('touchend', endDrag);
    }
  </script>
