<style>
    html {
      scroll-behavior: smooth;
      scroll-padding-top: 80px; /* Offset for top bar and spacing */
    }

    body {
      background-color: #131313;
      color: #e5e2e1;
      overflow-x: hidden;
    }

    .glass-card {
      background: rgba(18, 18, 18, 0.8);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 0.5px solid rgba(255, 255, 255, 0.05);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .glass-card:hover {
      border-color: rgba(0, 219, 233, 0.3);
      background: rgba(18, 18, 18, 0.9);
    }

    .pulse-cyan {
      animation: pulse-cyan 2s infinite;
    }

    @keyframes pulse-cyan {
      0% { box-shadow: 0 0 0 0 rgba(0, 219, 233, 0.4); }
      70% { box-shadow: 0 0 0 10px rgba(0, 219, 233, 0); }
      100% { box-shadow: 0 0 0 0 rgba(0, 219, 233, 0); }
    }

    .hotspot {
      width: 12px;
      height: 12px;
      background: #00dbe9;
      border-radius: 50%;
      position: absolute;
      cursor: pointer;
      transition: transform 0.3s ease;
      z-index: 10;
    }

    .hotspot::before {
      content: '';
      position: absolute;
      inset: -4px;
      border: 1px solid #00dbe9;
      border-radius: 50%;
      animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
    }

    @keyframes ping {
      75%, 100% { transform: scale(2.5); opacity: 0; }
    }

    .sos-slider-track {
      background: linear-gradient(to right, rgba(147, 0, 10, 0.1), rgba(147, 0, 10, 0.3));
    }

    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    .nav-link.active {
